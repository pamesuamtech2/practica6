// Ejercicio 13 : Clasificador de triángulos

let ladoA = parseFloat(prompt("Ingrese la longitud del primer lado:"));
let ladoB = parseFloat(prompt("Ingrese la longitud del segundo lado:"));
let ladoC = parseFloat(prompt("Ingrese la longitud del tercer lado:"));

if (ladoA === ladoB && ladoB === ladoC){
    alert ("Es un triángulo Equilátero")
}
else if (ladoA !== ladoB && ladoB !== ladoC && ladoA !== ladoC){
    alert ("Es un triángulo Escaleno")
}
else {
    alert ("Es un triángulo Isóseles")
}

// Ejercicio 14 : Simulador de cajero

